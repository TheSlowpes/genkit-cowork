{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "release-type": "go",
  "packages": {
    ".": {
      "component": "genkit-cowork"
    }
  },
  "changelog-sections": [
    {
      "type": "feat",
      "section": "Features"
    },
    {
      "type": "fix",
      "section": "Bug Fixes"
    },
    {
      "type": "docs",
      "section": "Documentation"
    },
    {
      "type": "test",
      "section": "Tests"
    },
    {
      "type": "refactor",
      "section": "Refactoring"
    }
  ],
  "extra-files": [
    {
      "type": "json",
      "path": "release-please-config.json",
      "jsonpath": "$.packages['.'].component"
    }
  ]
}
